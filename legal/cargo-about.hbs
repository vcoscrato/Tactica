{{!-- HTML template used by cargo-about; it is not shipped as a release file. --}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Tactica Rust dependency licenses</title>
  <style>
    body { font: 16px/1.5 system-ui, sans-serif; margin: 0; }
    main { max-width: 900px; margin: auto; padding: 2rem; }
    pre { border: 1px solid #bbb; padding: 1rem; white-space: pre-wrap; }
    @media (prefers-color-scheme: dark) {
      body { color: #eee; background: #222; }
      a { color: #8cc8ff; }
      pre { border-color: #666; }
    }
  </style>
</head>
<body>
<main>
  <h1>Rust dependency licenses</h1>
  <p>Generated from Tactica's locked Linux release dependency graph.</p>
  {{#each licenses}}
  <section>
    <h2 id="{{id}}">{{name}}</h2>
    <p>Used by:</p>
    <ul>
      {{#each used_by}}
      <li><a href="{{#if crate.repository}}{{crate.repository}}{{else}}https://crates.io/crates/{{crate.name}}{{/if}}">{{crate.name}} {{crate.version}}</a></li>
      {{/each}}
    </ul>
    <pre>{{text}}</pre>
  </section>
  {{/each}}
</main>
</body>
</html>
